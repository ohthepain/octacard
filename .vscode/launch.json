{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API: Debug server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "runtimeArgs": ["watch", "server/index.ts"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "${workspaceFolder}/node_modules/**"]
    },
    {
      "name": "API: Attach to process",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": ["<node_internals>/**", "${workspaceFolder}/node_modules/**"]
    },
    {
      "name": "Worker: Debug Essentia",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "program": "server/workers/essentia-worker.ts",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "${workspaceFolder}/node_modules/**"]
    },
    {
      "name": "Worker: Debug CLAP",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "program": "server/workers/clap-worker.ts",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "${workspaceFolder}/node_modules/**"]
    },
    {
      "name": "Web: Launch Chrome (Vite)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "start:dev",
      "sourceMaps": true,
      "perScriptSourcemaps": "yes",
      "skipFiles": ["<node_internals>/**"],
      "runtimeExecutable": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
      "runtimeArgs": ["--new-window", "--disable-extensions", "--no-first-run", "--no-default-browser-check"],
      "userDataDir": "${workspaceFolder}/.vscode/.chrome"
    },
    {
      "name": "Web: Launch Edge (Vite)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "start:dev",
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**"],
      "runtimeArgs": ["--new-window"],
      "userDataDir": "${workspaceFolder}/.vscode/.edge"
    },
    {
      "name": "Web: Attach Chrome (manual)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Web: Debug (Chrome)",
      "configurations": ["Web: Launch Chrome (Vite)"]
    },
    {
      "name": "Web: Debug (Edge)",
      "configurations": ["Web: Launch Edge (Vite)"]
    }
  ]
}
