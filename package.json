{
  "name": "octacard",
  "version": "1.0.7",
  "description": "OctaCard - Audio file management and conversion tool",
  "author": {
    "name": "Paul Wilkinson",
    "email": "cremoni@gmail.com"
  },
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "./",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:debug": "VITE_DEBUG_BUILD=1 vite build --mode development --minify false --sourcemap",
    "build:coverage": "VITE_DEBUG_BUILD=1 vite build --sourcemap",
    "start": "vite preview",
    "preview": "vite preview",
    "preview:it": "vite preview --host 127.0.0.1 --port 3010 --strictPort",
    "it": "node scripts/integration/smoke.mjs",
    "release-screenshots": "concurrently -k -s first -n preview,capture \"pnpm:preview:it\" \"wait-on http://127.0.0.1:3010 && E2E_BASE_URL=http://127.0.0.1:3010 node scripts/capture-release-screenshots.mjs\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e:coverage": "pnpm run build:coverage && concurrently -k -s first -n preview,e2e \"pnpm:preview:it\" \"wait-on http://127.0.0.1:3010 && E2E_BASE_URL=http://127.0.0.1:3010 pnpm exec playwright test --config=playwright.config.ts\"",
    "test:coverage:full": "pnpm run test:coverage && pnpm run test:e2e:coverage && node scripts/merge-coverage.mjs",
    "dev:it": "concurrently -k -s first -n dev,it \"pnpm run dev\" \"wait-on http://localhost:3000 && E2E_BASE_URL=http://localhost:3000 pnpm run it\"",
    "test:it": "pnpm run build && concurrently -k -s first -n preview,it \"pnpm:preview:it\" \"wait-on http://127.0.0.1:3010 && E2E_BASE_URL=http://127.0.0.1:3010 pnpm run it\"",
    "bump:version": "pnpm version patch --no-git-tag-version",
    "bump:patch": "pnpm version patch --no-git-tag-version",
    "bump:minor": "pnpm version minor --no-git-tag-version",
    "bump:major": "pnpm version major --no-git-tag-version",
    "clean": "rm -rf dist .tanstack",
    "clean:all": "pnpm run clean && rm -rf node_modules/.cache node_modules/.vite"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.163.3",
    "@tanstack/router-plugin": "^1.164.0",
    "@tanstack/router-vite-plugin": "^1.164.0",
    "@tanstack/start": "^1.120.20",
    "@tanstack/start-plugin": "^1.111.2",
    "@vitest/coverage-v8": "^4.0.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^0.576.0",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.356.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "wavesurfer.js": "^7.12.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@bgotink/playwright-coverage": "^0.3.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^22.19.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^18.3.7",
    "@types/wavesurfer.js": "^6.0.12",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "istanbul-merge": "^2.0.0",
    "jsdom": "^28.1.0",
    "nyc": "^18.0.0",
    "patch-package": "^8.0.1",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "pnpm": {
    "patchedDependencies": {
      "wavesurfer.js": "patches/wavesurfer.js.patch"
    }
  }
}
