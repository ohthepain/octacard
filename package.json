{
  "name": "octacard",
  "version": "1.0.7",
  "description": "OctaCard - Audio file management and conversion tool",
  "author": {
    "name": "Paul Wilkinson",
    "email": "cremoni@gmail.com"
  },
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "./",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:debug": "VITE_DEBUG_BUILD=1 vite build --mode development --minify false --sourcemap",
    "start": "vite preview",
    "preview": "vite preview",
    "preview:it": "vite preview --host 127.0.0.1 --port 3010 --strictPort",
    "it": "node scripts/integration/smoke.mjs",
    "dev:it": "concurrently -k -s first -n dev,it \"pnpm run dev\" \"wait-on http://localhost:3000 && E2E_BASE_URL=http://localhost:3000 pnpm run it\"",
    "test:it": "pnpm run build && concurrently -k -s first -n preview,it \"pnpm:preview:it\" \"wait-on http://127.0.0.1:3010 && E2E_BASE_URL=http://127.0.0.1:3010 pnpm run it\"",
    "bump:version": "pnpm version patch --no-git-tag-version",
    "bump:patch": "pnpm version patch --no-git-tag-version",
    "bump:minor": "pnpm version minor --no-git-tag-version",
    "bump:major": "pnpm version major --no-git-tag-version",
    "clean": "rm -rf dist .tanstack",
    "clean:all": "pnpm run clean && rm -rf node_modules/.cache node_modules/.vite"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "0.12.10",
    "@ffmpeg/util": "^0.12.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.163.2",
    "@tanstack/router-plugin": "^1.163.2",
    "@tanstack/router-vite-plugin": "^1.163.2",
    "@tanstack/start": "^1.120.20",
    "@tanstack/start-plugin": "^1.111.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^0.552.0",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.356.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^4.6.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "wavesurfer.js": "^7.12.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^22.19.13",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/wavesurfer.js": "^6.0.12",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.12",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "wait-on": "^9.0.4"
  }
}
