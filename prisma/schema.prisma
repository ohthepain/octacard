generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Better Auth models
model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  roles         UserRole[]
  ownedPacks    Pack[]              @relation("PackOwner")
  ownedSamples  PackSample[]       @relation("SampleOwner")
  collection    SampleCollection[]

  @@unique([email])
  @@map("user")
}

enum RoleName {
  ADMIN
  SUPERADMIN
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      RoleName
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role])
  @@map("user_role")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Pack {
  id                  String       @id @default(cuid())
  name                String
  ownerId             String
  parentId            String?
  coverImageS3Key     String?
  isPublic            Boolean      @default(true)
  priceTokens         Int          @default(0)
  defaultSampleTokens Int          @default(0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  owner               User         @relation("PackOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  parent              Pack?        @relation("PackHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children            Pack[]       @relation("PackHierarchy")
  packSamples         PackSample[]

  @@index([ownerId])
  @@index([parentId])
  @@index([name])
  @@map("pack")
}

// Sample = content identified by hash. Single source of truth; survives DB reset.
model Sample {
  id             String              @id
  s3Key          String               @unique
  contentType    String
  sizeBytes      Int?
  createdAt      DateTime            @default(now())
  // Basic measured scalars (from analysis)
  durationMs     Int?
  sampleRate     Int?
  channels       Int?
  analysisStatus SampleAnalysisStatus @default(PENDING)
  analysisError  String?
  packSamples    PackSample[]
  collections    SampleCollection[]
  attributes     SampleAttribute[]
  annotations    SampleAnnotation[]
  embeddings     SampleEmbedding[]

  @@map("sample")
}

enum SampleAnalysisStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

// Numeric continuous values from Essentia (brightness, energy, bpm, etc.)
model SampleAttribute {
  id       String  @id @default(cuid())
  sampleId String
  key      String  // brightness, energy, bpm, loudness, attack_ms, spectral_centroid, etc.
  value    Float
  sample   Sample  @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  @@unique([sampleId, key])
  @@index([sampleId])
  @@index([key])
  @@map("sample_attribute")
}

// Taxonomy attribute = descriptor category (style, instrument_type, mood, etc.)
model TaxonomyAttribute {
  id    String          @id @default(cuid())
  key   String          @unique // instrument_family, instrument_type, style, descriptor, mood
  values TaxonomyValue[]

  @@map("taxonomy_attribute")
}

// Taxonomy value = allowed canonical value within a category (techno, kick, moody, etc.)
model TaxonomyValue {
  id          String                    @id @default(cuid())
  attributeId String
  key         String                    // canonical ID: techno, kick, warm
  attribute   TaxonomyAttribute         @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  annotations SampleAnnotation[]
  translations TaxonomyValueTranslation[]

  @@unique([attributeId, key])
  @@index([attributeId])
  @@map("taxonomy_value")
}

// Sample ↔ taxonomy value assignment (from rule layer interpreting model output)
model SampleAnnotation {
  id           String        @id @default(cuid())
  sampleId     String
  taxonomyValueId String
  confidence   Float         // 0–1
  source       String        @default("rule") // rule, essentia, clap
  rank         Int?          // primary vs secondary
  sample       Sample        @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  taxonomyValue TaxonomyValue @relation(fields: [taxonomyValueId], references: [id], onDelete: Cascade)

  @@unique([sampleId, taxonomyValueId])
  @@index([sampleId])
  @@index([taxonomyValueId])
  @@map("sample_annotation")
}

// Embedding vectors for similarity search (CLAP, Essentia)
model SampleEmbedding {
  id        String   @id @default(cuid())
  sampleId  String
  model     String   // clap, essentia
  modelVersion String @default("v1")
  dimensions Int
  vector    Bytes?  // Embedding as float32 bytes; use raw SQL for pgvector when available
  sample    Sample   @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  @@unique([sampleId, model])
  @@index([sampleId])
  @@map("sample_embedding")
}

// Per-locale display labels for taxonomy values (localization)
model TaxonomyValueTranslation {
  id              String        @id @default(cuid())
  taxonomyValueId String
  locale          String        // en, de, etc.
  label           String
  taxonomyValue   TaxonomyValue @relation(fields: [taxonomyValueId], references: [id], onDelete: Cascade)

  @@unique([taxonomyValueId, locale])
  @@index([taxonomyValueId])
  @@map("taxonomy_value_translation")
}

// Pack's reference to a sample. Sample ID = content hash.
model PackSample {
  packId     String
  sampleId   String
  name       String
  ownerId    String
  credits    Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  pack       Pack           @relation(fields: [packId], references: [id], onDelete: Cascade)
  owner      User           @relation("SampleOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  sample     Sample         @relation(fields: [sampleId], references: [id], onDelete: Restrict)

  @@id([packId, sampleId])
  @@index([ownerId])
  @@index([name])
  @@index([credits])
  @@index([sampleId])
  @@map("pack_sample")
}

model SampleCollection {
  id          String   @id @default(cuid())
  userId      String
  sampleId    String
  creditsPaid Int
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sample      Sample   @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  @@unique([userId, sampleId])
  @@index([sampleId])
  @@map("sample_collection")
}
