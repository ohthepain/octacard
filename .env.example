# App
NODE_ENV=development

# Postgres (local: docker-compose, AWS: RDS)
DATABASE_URL=postgresql://octacard:octacard_dev@localhost:5432/octacard

# Redis (local: docker-compose, AWS: ElastiCache)
REDIS_URL=redis://localhost:6379

# S3 (local: LocalStack or MinIO, AWS: real S3)
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=octacard-uploads
S3_ENDPOINT=
# For local MinIO: http://localhost:9000
# For LocalStack: http://localhost:4566
# Leave empty for real AWS S3

# Auth (Better Auth) - sessions stored in Redis via secondaryStorage
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# API (Hono server)
API_PORT=3001
API_VERSION=1.0.0
API_MIN_CLIENT_VERSION=1.0.0
# OAuth (optional)
BETTER_AUTH_GOOGLE_CLIENT_ID=
BETTER_AUTH_GOOGLE_CLIENT_SECRET=

# Existing
APPLE_TEAM_ID=
WHATSAPP_NUMBER=
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
