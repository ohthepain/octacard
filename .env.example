# App
NODE_ENV=development
# Enable verbose debug output from deps (ioredis, pg, bullmq, etc.) when running locally.
# Or run: pnpm run dev:debug
# DEBUG=*

# Postgres (local: docker-compose, AWS: RDS)
DATABASE_URL=postgresql://octacard:octacard_dev@localhost:5432/octacard
# Optional DB CA certificate for private/self-signed chains in production.
# Use ONE of these:
# DATABASE_CA_CERT_PATH=/run/secrets/db-ca.pem
# DATABASE_CA_CERT_BASE64=LS0tLS1CRUdJTiBDRVJUSUZJQ0FURS0tLS0t...
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Redis (local: docker-compose, AWS: ElastiCache)
REDIS_URL=redis://localhost:6379

# S3 (local: use staging bucket; AWS: ECS injects per-environment)
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=octacard-staging-uploads
S3_ENDPOINT=
# For local MinIO: http://localhost:9000
# For LocalStack: http://localhost:4566
# Leave empty for real AWS S3

# Auth (Better Auth) - sessions stored in Redis via secondaryStorage
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
AUTH_SUPERADMIN_EMAILS=cremoni@gmail.com
# SES - leave empty for local dev (registration works without email verification).
# Production: no-reply@octacard.live (domain must be verified in SES)
SES_FROM_EMAIL=
SES_CONFIGURATION_SET=

# API (Hono server)
API_PORT=3001
API_VERSION=1.0.0
API_MIN_CLIENT_VERSION=1.0.0
# Start sample analysis worker in the API process (default: true).
# Set to "false" if you run dedicated worker process(es) separately.
SAMPLE_ANALYSIS_WORKER_ENABLED=true
# Seed taxonomy on container boot (default: true). Recommended for staging/production.
SEED_TAXONOMY_ON_START=true
# OAuth (optional)
BETTER_AUTH_GOOGLE_CLIENT_ID=
BETTER_AUTH_GOOGLE_CLIENT_SECRET=

# Unsplash (optional - for random cover images in create/edit pack)
# Use UNSPLASH_ACCESS_KEY for API auth (Client-ID). Application ID and Secret are for OAuth.
UNSPLASH_ACCESS_KEY=
# UNSPLASH_APPLICATION_ID=
# UNSPLASH_SECRET_KEY=

# Existing
APPLE_TEAM_ID=
WHATSAPP_NUMBER=
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
